  "https://mmbiz.qpic.cn/mmbiz_jpg/gT0ancicibROTAuj081qI7XNKc5KhNkloF3NbQ7ldUwDJp4Bjr5k9n6xDIFMSIfhf66rFlWCZ7ggnEn2RM5qUkNIaGXibUeNY8o2ia1j7Z56Zqk/640?wx_fmt=jpeg&from=appmsg": {
    "ocr": "# 产品\n\n# 名称\n\n# 太B香港\n\n# 世D悦享III\n\n<table><tr><td>缴费期</td><td colspan=\"2\">趸缴</td><td colspan=\"2\">2年</td><td colspan=\"2\">5年</td><td colspan=\"2\">10年</td></tr><tr><td>保单年度</td><td>保证IRR</td><td>预期IRR</td><td>保证IRR</td><td>预期IRR</td><td>保证IRR</td><td>预期IRR</td><td>保证IRR</td><td>预期IRR</td></tr><tr><td>10年</td><td>-0.10%</td><td>4.52%</td><td>-0.36%</td><td>4.02%</td><td>-0.48%</td><td>3.50%</td><td>-0.93%</td><td>0.55%</td></tr><tr><td>15年</td><td>0.13%</td><td>5.69%</td><td>0.12%</td><td>5.50%</td><td>0.06%</td><td>5.02%</td><td>0.00%</td><td>4.20%</td></tr><tr><td>20年</td><td>0.21%</td><td>6.15%</td><td>0.20%</td><td>6.10%</td><td>0.15%</td><td>6.02%</td><td>0.10%</td><td>5.81%</td></tr><tr><td>30年</td><td>0.36%</td><td>6.50%</td><td>0.35%</td><td>6.50%</td><td>0.30%</td><td>6.50%</td><td>0.25%</td><td>6.43%</td></tr><tr><td>40年</td><td>0.43%</td><td>6.50%</td><td>0.41%</td><td>6.50%</td><td>0.36%</td><td>6.50%</td><td>0.31%</td><td>6.50%</td></tr><tr><td>50年</td><td>0.46%</td><td>6.50%</td><td>0.45%</td><td>6.50%</td><td>0.40%</td><td>6.50%</td><td>0.36%</td><td>6.50%</td></tr><tr><td>100年</td><td>0.54%</td><td>6.50%</td><td>0.53%</td><td>6.50%</td><td>0.48%</td><td>6.50%</td><td>0.43%</td><td>6.50%</td></tr><tr><td>130年</td><td>0.56%</td><td>6.50%</td><td>0.55%</td><td>6.50%</td><td>0.50%</td><td>6.50%</td><td>0.45%</td><td>6.50%</td></tr><tr><td>保证回本期</td><td colspan=\"2\">11年</td><td colspan=\"2\">11年</td><td colspan=\"2\">13年</td><td colspan=\"2\">15年</td></tr><tr><td>预期回本期</td><td colspan=\"2\">4年</td><td colspan=\"2\">5年</td><td colspan=\"2\">6年</td><td colspan=\"2\">9年</td></tr></table>",
