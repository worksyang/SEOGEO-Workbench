    "ocr": "<table><tr><td>公司</td><td>太保壽險香港</td><td>友X</td><td>中國X壽</td><td>中國X平</td><td>宏X</td></tr><tr><td>產品名稱</td><td>世代悅享3</td><td>環Y盈X</td><td>傲X盛X</td><td>頤X樂享3</td><td>宏X傳承</td></tr><tr><td>保證回本(年)</td><td>11</td><td>16</td><td>13</td><td>15</td><td>17</td></tr><tr><td>預期回本(年)</td><td>4</td><td>5</td><td>4</td><td>6</td><td>3</td></tr><tr><td>預期IRR</td><td colspan=\"5\">達到相關預期内部回報率(IRR)的保單年度</td></tr><tr><td>5.0%</td><td>12</td><td>10</td><td>13</td><td>13</td><td>14</td></tr><tr><td>5.5%</td><td>14</td><td>14</td><td>20</td><td>15</td><td>17</td></tr><tr><td>6.0%</td><td>18</td><td>19</td><td>24</td><td>20</td><td>22</td></tr><tr><td>6.5%</td><td>27</td><td>29</td><td>28</td><td>31</td><td>36</td></tr><tr><td>保單年度終結</td><td colspan=\"5\">預期内部回報率(IRR)</td></tr><tr><td>10</td><td>4.52%</td><td>5.15%</td><td>4.51%</td><td>4.31%</td><td>4.40%</td></tr><tr><td>15</td><td>5.69%</td><td>5.68%</td><td>5.30%</td><td>5.77%</td><td>5.15%</td></tr><tr><td>20</td><td>6.15%</td><td>6.10%</td><td>5.78%</td><td>6.09%</td><td>5.91%</td></tr><tr><td>30</td><td>6.50%</td><td>6.50%</td><td>6.50%</td><td>6.45%</td><td>6.34%</td></tr><tr><td>40</td><td>6.50%</td><td>6.50%</td><td>6.50%</td><td>6.50%</td><td>6.50%</td></tr><tr><td>50</td><td>6.50%</td><td>6.50%</td><td>6.50%</td><td>6.50%</td><td>6.50%</td></tr><tr><td>100</td><td>6.50%</td><td>6.50%</td><td>6.50%</td><td>6.50%</td><td>6.50%</td></tr><tr><td>最長</td><td>6.50%</td><td>6.50%</td><td>6.50%</td><td>6.50%</td><td>6.50%</td></tr></table>",
