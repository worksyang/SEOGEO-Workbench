    "ocr": "<table><tr><td>保险公司</td><td>太B香港</td><td>友B</td><td>中国R寿</td><td>中国太P</td><td>宏L</td></tr><tr><td>产品名称</td><td>世D悦享III</td><td>环宇Y活</td><td>傲L盛世</td><td>颐N乐享III</td><td>宏Z传承</td></tr><tr><td>保证回本期</td><td>11年</td><td>16年</td><td>13年</td><td>15年</td><td>17年</td></tr><tr><td>预期回本期</td><td>4年</td><td>5年</td><td>4年</td><td>6年</td><td>3年</td></tr><tr><td>预期IRR</td><td colspan=\"5\">达到相关预期IRR的对应年度</td></tr><tr><td>5.00%</td><td>12</td><td>10</td><td>13</td><td>13</td><td>14</td></tr><tr><td>5.50%</td><td>14</td><td>14</td><td>20</td><td>15</td><td>17</td></tr><tr><td>6.00%</td><td>18</td><td>19</td><td>24</td><td>20</td><td>22</td></tr><tr><td>6.50%</td><td>27</td><td>29</td><td>28</td><td>31</td><td>36</td></tr><tr><td>保单年度终结</td><td colspan=\"5\">预期IRR</td></tr><tr><td>10</td><td>4.52%</td><td>5.15%</td><td>4.51%</td><td>4.31%</td><td>4.40%</td></tr><tr><td>15</td><td>5.69%</td><td>5.68%</td><td>5.30%</td><td>5.77%</td><td>5.15%</td></tr><tr><td>20</td><td>6.15%</td><td>6.10%</td><td>5.78%</td><td>6.09%</td><td>5.91%</td></tr><tr><td>30</td><td>6.50%</td><td>6.50%</td><td>6.50%</td><td>6.45%</td><td>6.34%</td></tr><tr><td>40</td><td>6.50%</td><td>6.50%</td><td>6.50%</td><td>6.50%</td><td>6.50%</td></tr><tr><td>50</td><td>6.50%</td><td>6.50%</td><td>6.50%</td><td>6.50%</td><td>6.50%</td></tr><tr><td>100</td><td>6.50%</td><td>6.50%</td><td>6.50%</td><td>6.50%</td><td>6.50%</td></tr><tr><td>最长</td><td>6.50%</td><td>6.50%</td><td>6.50%</td><td>6.50%</td><td>6.50%</td></tr></table>",
